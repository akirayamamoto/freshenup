{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "platformAutomerge": false,
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "automerge": true,
  "packageRules": [
    {
      "description": "pydantic (only runtime dep): widen the >=2,<3 cap when a new major lands",
      "matchPackageNames": ["pydantic"],
      "rangeStrategy": "widen"
    },
    {
      "description": "Hold pydantic majors — Renovate opens the cap-widening PR, the manual merge is the gate",
      "matchPackageNames": ["pydantic"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
